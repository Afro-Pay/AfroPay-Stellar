# ===========================================
# AfroPay-Stellar Environment Variables
# ===========================================
# Copy this file to .env and fill in values.
# See docs/environment-variables.md for full reference.

# --- API (apps/api/) ---
PORT=3001
DATABASE_URL=postgresql://remitx:remitx@localhost:5432/remitx

# ---- Redis / Queue ----
REDIS_URL=redis://localhost:6379
NODE_ENV=development

# Secrets (never commit real values)
JWT_SECRET=change_me_in_production
JWT_REFRESH_SECRET=change_me_in_production_refresh
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# 32-byte hex master key for AES-256-GCM wallet encryption.
# Per-user keys are derived with HKDF using the userId as info.
# Replace this placeholder with a random value before running locally or in production.
ENCRYPTION_KEY=00112233445566778899aabbccddeeff00112233445566778899aabbccddeeff

STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# ---- Anchors (SEP-6) ----
ANCHOR_USDC_URL=https://testanchor.stellar.org
ANCHOR_NGN_URL=https://testanchor.stellar.org

# --- Frontend (apps/frontend/) ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Rust Worker (services/rust-worker/) ---
METRICS_PORT=9898
WORKER_CONCURRENCY=10

# Multi-Signature Configuration
COSIGNER_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MULTISIG_THRESHOLD_USD=10000
