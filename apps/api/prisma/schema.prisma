generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Allowed lifecycle states for a Transaction.
enum TransactionStatus {
  PENDING
  RETRYING
  SUCCESS
  FAILED
}

/// Allowed lifecycle states for KYC records.
enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

/// KYC verification tiers.
enum KycTier {
  NONE
  BASIC
  FULL
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  wallet       Wallet?
  transactions Transaction[]
  kyc          KycRecord?
}

model Wallet {
  id              String        @id @default(uuid())
  /// Foreign key to the owning User. One wallet per user (enforced by @unique).
  userId          String        @unique
  /// Stellar public key – must be globally unique.
  publicKey       String        @unique
  encryptedSecret String
  encryptedDek    String?
  kmsKeyId        String?
  createdAt       DateTime      @default(now())
  /// Automatically updated whenever the wallet record changes (e.g. key rotation).
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
}

model Transaction {
  id             String            @id @default(uuid())
  /// Foreign key to the User who initiated this transaction.
  userId         String
  /// Foreign key to the Wallet used for this transaction.
  walletId       String
  /// Stellar destination public key – required, never null.
  destination    String
  /// Transfer amount as a string to preserve decimal precision – required.
  amount         String
  /// Stellar asset code (e.g. "XLM", "USDC") – required.
  assetCode      String
  /// Asset issuer account; null for native XLM.
  assetIssuer    String?
  /// Optional transaction memo.
  memo           String?
  /// Lifecycle state of this transaction.
  status         TransactionStatus @default(PENDING)
  /// Stellar transaction hash once submitted; unique across all confirmed txs.
  stellarTxHash  String?           @unique
  /// Fraud risk score from the analytics service.
  riskScore      Float?
  /// Whether this transaction has been flagged for review.
  flagged        Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Restrict)

  /// Speeds up per-user history queries (ordered by newest first).
  @@index([userId, createdAt(sort: Desc)])
  /// Speeds up per-wallet history queries.
  @@index([walletId, createdAt(sort: Desc)])
}

model KycRecord {
  id              String        @id @default(uuid())
  userId          String        @unique
  status          KycStatus     @default(PENDING)
  tier            KycTier       @default(NONE)
  documentType    String?
  documentRef     String?
  submittedAt     DateTime?
  reviewedAt      DateTime?
  rejectionReason String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}
